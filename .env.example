# NanoClaw Configuration File
# Copy this file to .env and fill in your configuration

# ═══════════════════════════════════════════════════════════
# Basic Settings
# ═══════════════════════════════════════════════════════════

# Assistant name (used in trigger phrases like @Andy)
ASSISTANT_NAME=Andy

# Whether the assistant has its own phone number
# Set to true if the bot account has a dedicated number
ASSISTANT_HAS_OWN_NUMBER=false

# ═══════════════════════════════════════════════════════════
# QQ Bot Configuration (Optional)
# Required if you want to use QQ channel
# ═══════════════════════════════════════════════════════════

# QQ Bot App ID (from QQ Developer Platform)
QQ_APP_ID=your_qq_app_id

# QQ Bot Client Secret (from QQ Developer Platform)
QQ_CLIENT_SECRET=your_qq_client_secret

# ═══════════════════════════════════════════════════════════
# WhatsApp Configuration (Optional)
# Required if you want to use WhatsApp channel
# ═══════════════════════════════════════════════════════════

# WhatsApp phone number (with country code, e.g., +1234567890)
# WHATSAPP_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════
# Container Configuration
# ═══════════════════════════════════════════════════════════

# Run in native mode (no containers)
# Set to true to run agents directly on host system
# Set to false to use Docker containers (requires Docker Desktop)
NATIVE_MODE=true

# Container image name (only used if NATIVE_MODE=false)
# CONTAINER_IMAGE=nanoclaw-agent:latest

# Container timeout in milliseconds (default: 30 minutes)
# CONTAINER_TIMEOUT=1800000

# Maximum concurrent containers (default: 5)
# MAX_CONCURRENT_CONTAINERS=5

# ═══════════════════════════════════════════════════════════
# Debug Configuration
# ═══════════════════════════════════════════════════════════

# Log level: debug, info, warn, error
# LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════
# Qwen Code Configuration
# ═══════════════════════════════════════════════════════════

# Approval mode: plan | default | auto-edit | yolo
# - plan: Read-only analysis, no modifications
# - default: Require approval for all operations
# - auto-edit: Auto-approve file edits, require approval for shell commands (recommended)
# - yolo: Fully automated, no approvals (use with caution)
APPROVAL_MODE=auto-edit

# Output format: text | json
# - text: Human-readable plain text output (saves 20x tokens)
# - json: Structured JSON output with metadata (usage stats, tool calls, etc.)
QWEN_OUTPUT_FORMAT=text

# ═══════════════════════════════════════════════════════════
# Setup Instructions
# ═══════════════════════════════════════════════════════════
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your credentials
# 3. Run setup wizard: npx tsx setup/index.ts
# 4. Start application: npm start
#
# For Windows users:
# 1. Copy this file: copy .env.example .env
# 2. Edit .env with your credentials
# 3. Run setup script: .\setup.ps1
# 4. Start application: npm start
#
# Qwen Code Setup (if using AI features):
# 1. Install: npm install -g @qwen-code/qwen-code
# 2. Configure: npx qwen-code setup
# 3. Enable tools: Add to ~/.qwen/settings.json:
#    {
#      "tools": {
#        "experimental": { "skills": true },
#        "allowed": ["web_fetch"]
#      }
#    }
#
# ═══════════════════════════════════════════════════════════
