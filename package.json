{
  "name": "qwqnanoclaw",
  "version": "1.1.2",
  "description": "Personal AI assistant powered by Qwen Code. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "setup": "tsx setup/index.ts",
    "config": "tsx setup/config-manager.ts",
    "config:name": "tsx setup/config-manager.ts name",
    "config:language": "tsx setup/config-manager.ts language",
    "config:show": "tsx setup/config-manager.ts show",
    "init": "tsx scripts/init.ts",
    "reset": "tsx scripts/reset.ts",
    "reset:force": "tsx scripts/reset.ts --force",
    "clean": "npm run reset && npm run init",
    "build-container": "docker build -t nanoclaw-agent:latest ./container",
    "build-container:sudo": "sudo docker build -t nanoclaw-agent:latest ./container",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.9",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.6.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sql.js": "^1.14.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
